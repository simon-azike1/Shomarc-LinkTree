{
  "version": 2,
  "buildCommand": "cd frontend && npm install && node node_modules/vite/bin/vite.js build && cd ../backend && npm install",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/server.js": { "runtime": "@vercel/node@3.2.7" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/(.*\\.(js|css|png|jpg|svg|ico|json))", "dest": "/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}